# Environment variables
.env
.env.local
.env.production
.env*.local

# Dependencies
node_modules/

# Runtime data
uploads/*
!uploads/.gitkeep
data/search-tokens/*
!data/search-tokens/.gitkeep

# Build output
dist/
build/
.next/

# Snapshot tarballs - keep raw archives out of git
servers/*/snapshots/*.tar.gz
servers/*/snapshots/*.tgz

# Anything explicitly marked as containing secrets
**/secret-*
**/*.private
**/*.pem
**/*.key
!**/cert-inventory.txt

# Local-only review notes
SCRATCH.md
.scratch/

# OS files
.DS_Store
Thumbs.db
