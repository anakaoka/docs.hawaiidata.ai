# Required service integrations
SENDGRID_API_KEY=
OPENAI_API_KEY=

# Twilio Verify demo
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# PostgreSQL
DATABASE_URL=postgres://docsapp:CHANGE_ME@127.0.0.1:5432/docs_hawaiidata

# App runtime
PORT=3000
NODE_ENV=production
SESSION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# AES-256-GCM encryption key for encrypted document storage.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional setup/test helpers
DOCSAPP_DB_PASSWORD=
SEED_USER_PASSWORD=
TEST_BASE_URL=https://docs.hawaiidata.ai
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
