<%- include('partials/header') %>

  <div class="dashboard-layout">
    <aside class="sidebar">
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <div style="padding: 0.5rem 1rem 0.75rem; margin-bottom: 0.25rem; border-bottom: 1px solid var(--neutral-700, #374151);">
          <span style="display: inline-block; padding: 0.2rem 0.5rem; font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; background: rgba(249, 115, 22, 0.15); color: var(--orange-400, #fb923c); border: 1px solid rgba(249, 115, 22, 0.3); border-radius: 3px;">Admin</span>
        </div>
      <% } %>
      <ul class="sidebar-nav">
        <li><a href="/dashboard">&#128202; Overview</a></li>
        <li><a href="/dashboard/documents">&#128196; Documents</a></li>
        <li><a href="/dashboard/search">&#128269; Search</a></li>
        <li><a href="/dashboard/upload">&#128228; Upload</a></li>
        <li><a href="/dashboard/audit">&#128203; Audit Log</a></li>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <li><a href="/dashboard/tenants">&#127970; Tenants</a></li>
        <% } %>
        <li><a href="/dashboard/settings" class="active">&#9881; Settings</a></li>
        <li><a href="/dashboard/suggestions">&#128161; Suggestions</a></li>
        <li><a href="/dashboard/token-usage">&#9889; Token Usage</a></li>
      </ul>
    </aside>
    <main class="main-content">
      <div class="page-header">
        <h1>Settings</h1>
      </div>

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>

      <div class="card" style="margin-bottom: var(--space-xl);">
        <div class="card-header">
          <span class="card-title">Profile</span>
        </div>
        <form action="/dashboard/settings" method="POST">
          <div class="form-group">
            <label for="full_name">Full Name</label>
            <input type="text" id="full_name" name="full_name" class="form-input" value="<%= user.full_name || '' %>">
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" class="form-input" value="<%= user.email %>" disabled>
          </div>
          <div class="form-group">
            <label for="phone">Phone Number (for SMS verification)</label>
            <input type="tel" id="phone" name="phone" class="form-input" placeholder="+1 (808) 555-1234" value="<%= user.phone || '' %>">
          </div>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">Change Password</span>
        </div>
        <form action="/dashboard/settings/password" method="POST">
          <div class="form-group">
            <label for="current_password">Current Password</label>
            <input type="password" id="current_password" name="current_password" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="new_password">New Password</label>
            <input type="password" id="new_password" name="new_password" class="form-input" required>
          </div>
          <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
      </div>
    </main>
  </div>

<%- include('partials/footer') %>
