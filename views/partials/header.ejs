<!DOCTYPE html>
<html lang="en" data-theme="dark">
<script>
  (function(){var t=localStorage.getItem('theme');if(t==='light')document.documentElement.setAttribute('data-theme','light');})();
</script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>docs.hawaiidata.ai</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-title" content="Docs HawaiiData.ai">
  <meta name="application-name" content="Docs HawaiiData.ai">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%= (typeof impersonating !== 'undefined' && impersonating) ? 'has-impersonation-banner' : '' %>">
  <nav class="navbar">
    <div class="nav-container">
      <a href="<%= (typeof user !== 'undefined' && user) ? '/dashboard' : '/' %>" class="nav-logo">
        <svg class="nav-logo-icon" width="28" height="28" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <rect x="15" y="5" width="55" height="72" rx="6" fill="#2DB252"/>
          <rect x="30" y="18" width="60" height="72" rx="6" fill="#1d8a3e"/>
          <rect x="38" y="34" width="36" height="4" rx="2" fill="#a8e0b8"/>
          <rect x="38" y="44" width="28" height="4" rx="2" fill="#a8e0b8"/>
          <rect x="38" y="54" width="32" height="4" rx="2" fill="#a8e0b8"/>
          <circle cx="68" cy="72" r="18" fill="#0b0f1a" stroke="#f97316" stroke-width="3"/>
          <rect x="62" y="64" width="12" height="10" rx="3" fill="#f97316"/>
          <path d="M64 64 V60 A4 4 0 0 1 72 60 V64" fill="none" stroke="#f97316" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
        <span class="logo-text"><span class="logo-accent">docs.</span>HawaiiData.ai</span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">&#9776;</button>
      <ul class="nav-links">
        <% if (typeof user !== 'undefined' && user) { %>
          <li><a href="/dashboard">Dashboard</a></li>
          <li><a href="/dashboard/verify-demo">2FA Demo</a></li>
          <li>
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
              <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
            </button>
          </li>
          <li><a href="/auth/logout" class="btn btn-sm btn-logout">Logout</a></li>
        <% } else { %>
          <li><a href="/#features">Features</a></li>
          <li><a href="/#how-it-works">How It Works</a></li>
          <li><a href="/#industries">Industries</a></li>
          <li>
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
              <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
            </button>
          </li>
          <li><a href="/auth/login" class="btn btn-sm btn-primary">Sign In</a></li>
        <% } %>
      </ul>
    </div>
  </nav>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var navToggle = document.getElementById('navToggle');
      if (navToggle) {
        navToggle.addEventListener('click', function() {
          document.querySelector('.nav-links').classList.toggle('open');
        });
      }
      var btn = document.getElementById('themeToggle');
      if (!btn) return;
      btn.addEventListener('click', function() {
        var html = document.documentElement;
        var current = html.getAttribute('data-theme');
        var next = current === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    });
  </script>
  <% if (typeof impersonating !== 'undefined' && impersonating) { %>
    <div class="impersonation-banner">
      <span>Viewing as <strong><%= impersonating.name %></strong></span>
      <form method="POST" action="/dashboard/tenants/exit" style="display: inline; margin: 0;">
        <button type="submit" class="btn btn-sm" style="background: var(--white); color: var(--orange-600); font-weight: 600; margin-left: 1rem; padding: 0.25rem 0.75rem;">Exit Workspace</button>
      </form>
    </div>
  <% } %>
