<%- include('partials/header') %>

  <div class="dashboard-layout">
    <aside class="sidebar">
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <div style="padding: 0.5rem 1rem 0.75rem; margin-bottom: 0.25rem; border-bottom: 1px solid var(--neutral-700, #374151);">
          <span style="display: inline-block; padding: 0.2rem 0.5rem; font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; background: rgba(249, 115, 22, 0.15); color: var(--orange-400, #fb923c); border: 1px solid rgba(249, 115, 22, 0.3); border-radius: 3px;">Admin</span>
        </div>
      <% } %>
      <ul class="sidebar-nav">
        <li><a href="/dashboard">&#128202; Overview</a></li>
        <li><a href="/dashboard/documents">&#128196; Documents</a></li>
        <li><a href="/dashboard/search">&#128269; Search</a></li>
        <li><a href="/dashboard/upload">&#128228; Upload</a></li>
        <li><a href="/dashboard/audit" class="active">&#128203; Audit Log</a></li>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <li><a href="/dashboard/tenants">&#127970; Tenants</a></li>
        <% } %>
        <li><a href="/dashboard/settings">&#9881; Settings</a></li>
        <li><a href="/dashboard/suggestions">&#128161; Suggestions</a></li>
        <li><a href="/dashboard/token-usage">&#9889; Token Usage</a></li>
      </ul>
    </aside>
    <main class="main-content">
      <div class="page-header">
        <h1>Audit Log</h1>
      </div>

      <div class="card" style="margin-bottom: var(--space-xl);">
        <form id="audit-search-form" style="display: flex; gap: var(--space-md); align-items: flex-end;">
          <div class="form-group" style="flex: 1; margin-bottom: 0;">
            <label for="audit-query">Search Audit Logs</label>
            <input type="text" id="audit-query" class="form-input" placeholder='Try: "Show documents John viewed last week"'>
          </div>
          <button type="submit" class="btn btn-primary">Search</button>
        </form>
      </div>

      <div class="card">
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Action</th>
                <th>User</th>
                <th>Entity Type</th>
                <th>Details</th>
                <th>IP</th>
                <th>Timestamp</th>
              </tr>
            </thead>
            <tbody>
              <% if (logs && logs.length > 0) { %>
                <% logs.forEach(log => { %>
                  <tr>
                    <td><span class="badge badge-info"><%= log.action %></span></td>
                    <td><%= log.user_email || 'System' %></td>
                    <td><%= log.entity_type || '—' %></td>
                    <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= log.metadata ? JSON.stringify(log.metadata).slice(0, 60) : '—' %></td>
                    <td><%= log.ip_address || '—' %></td>
                    <td><%= formatDate(log.created_at) %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="6" style="text-align: center; color: var(--neutral-500);">No audit logs yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

<%- include('partials/footer') %>
